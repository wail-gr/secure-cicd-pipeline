# =============================================================================
# Environment Configuration
# =============================================================================
# Copy to .env for local development. DO NOT commit .env to version control.
# =============================================================================

# Application
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=debug

# GCP (for deployment scripts)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_AR_REPO=secure-cicd

# Cloud Run
CLOUD_RUN_SERVICE=secure-api
CLOUD_RUN_REGION=us-central1
